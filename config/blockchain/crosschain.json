{
    "version": "1.0.0",
    "network": "mainnet",
    "bridges": {
        "wbtc_ethereum": {
            "name": "Wrapped Bitcoin (Ethereum)",
            "source_protocol": "bitcoin",
            "destination_protocol": "ethereum",
            "enabled": true,
            "fee_percentage": 0.1,
            "min_transfer_amount": 0.001,
            "contract_address": "0x2260FAC5E5542a773Aa44fBCfeDf7C193bc2C599",
            "rpc_url": "${ETHEREUM_MAINNET_RPC:https://eth.llamarpc.com}",
            "ws_url": "${ETHEREUM_MAINNET_WS_URL:wss://mainnet.infura.io/ws/v3/${INFURA_API_KEY:}}",
            "explorer_url": "https://etherscan.io/token/0x2260FAC5E5542a773Aa44fBCfeDf7C193bc2C599",
            "abi": "${WBTC_ABI:}",
            "decimals": 8
        },
        "wbtc_binance": {
            "name": "Wrapped Bitcoin (Binance Smart Chain)",
            "source_protocol": "bitcoin",
            "destination_protocol": "binance-smart-chain",
            "enabled": true,
            "fee_percentage": 0.15,
            "min_transfer_amount": 0.001,
            "contract_address": "0x7130d2A12B9BCbFAe4f2634d864A1Ee1Ce3Ead9c",
            "rpc_url": "${BSC_MAINNET_RPC:https://bsc-dataseed.binance.org}",
            "ws_url": "${BSC_MAINNET_WS_URL:wss://bsc-ws-node.nariox.org:443}",
            "explorer_url": "https://bscscan.com/token/0x7130d2A12B9BCbFAe4f2634d864A1Ee1Ce3Ead9c",
            "abi": "${BSC_WBTC_ABI:}",
            "decimals": 18
        },
        "renbtc_ethereum": {
            "name": "RenBTC (Ethereum)",
            "source_protocol": "bitcoin",
            "destination_protocol": "ethereum",
            "enabled": true,
            "fee_percentage": 0.2,
            "min_transfer_amount": 0.0005,
            "contract_address": "0xEB4C2781e4ebA804CE9a9803C67d0893436bB27D",
            "rpc_url": "${ETHEREUM_MAINNET_RPC:https://eth.llamarpc.com}",
            "ws_url": "${ETHEREUM_MAINNET_WS_URL:wss://mainnet.infura.io/ws/v3/${INFURA_API_KEY:}}",
            "explorer_url": "https://etherscan.io/token/0xEB4C2781e4ebA804CE9a9803C67d0893436bB27D",
            "abi": "${REN_BTC_ABI:}",
            "decimals": 8
        },
        "usdc_ethereum": {
            "name": "USD Coin (Ethereum)",
            "source_protocol": "ethereum",
            "destination_protocol": "binance-smart-chain",
            "enabled": true,
            "fee_percentage": 0.1,
            "min_transfer_amount": 10,
            "contract_address": "0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48",
            "rpc_url": "${ETHEREUM_MAINNET_RPC:https://eth.llamarpc.com}",
            "ws_url": "${ETHEREUM_MAINNET_WS_URL:wss://mainnet.infura.io/ws/v3/${INFURA_API_KEY:}}",
            "explorer_url": "https://etherscan.io/token/0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48",
            "decimals": 6
        }
    },
    "price_sources": {
        "internal": {
            "enabled": true,
            "update_interval": 300,
            "default_rates": {
                "bitcoin_ethereum": 15.5,
                "ethereum_bitcoin": 0.065,
                "bitcoin_binance_smart_chain": 15.2,
                "binance_smart_chain_bitcoin": 0.066,
                "ethereum_binance_smart_chain": 0.99,
                "binance_smart_chain_ethereum": 1.01
            }
        },
        "coingecko": {
            "api_url": "https://api.coingecko.com/api/v3",
            "enabled": true,
            "update_interval": 300,
            "api_key": "${COINGECKO_API_KEY:}",
            "rate_limit": 50,
            "timeout": 30,
            "retries": 3
        },
        "defillama": {
            "api_url": "https://coins.llama.fi",
            "enabled": true,
            "update_interval": 300,
            "timeout": 30,
            "retries": 3
        },
        "cryptocompare": {
            "api_url": "https://min-api.cryptocompare.com/data",
            "enabled": true,
            "api_key": "${CRYPTOCOMPARE_API_KEY:}",
            "update_interval": 300,
            "rate_limit": 100,
            "timeout": 30
        }
    },
    "rpc_endpoints": {
        "ethereum": {
            "mainnet": "${ETHEREUM_MAINNET_RPC:https://eth.llamarpc.com}",
            "ws_mainnet": "${ETHEREUM_MAINNET_WS_URL:wss://mainnet.infura.io/ws/v3/${INFURA_API_KEY:}}"
        },
        "binance-smart-chain": {
            "mainnet": "${BSC_MAINNET_RPC:https://bsc-dataseed.binance.org}",
            "ws_mainnet": "${BSC_MAINNET_WS_URL:wss://bsc-ws-node.nariox.org:443}"
        },
        "bitcoin": {
            "mainnet": "${BITCOIN_MAINNET_RPC:https://blockstream.info/api}",
            "mainnet_auth": "${BITCOIN_MAINNET_AUTH:user:pass}"
        },
        "polygon": {
            "mainnet": "${POLYGON_MAINNET_RPC:https://polygon-rpc.com}"
        },
        "arbitrum": {
            "mainnet": "${ARBITRUM_MAINNET_RPC:https://arb1.arbitrum.io/rpc}"
        },
        "optimism": {
            "mainnet": "${OPTIMISM_MAINNET_RPC:https://mainnet.optimism.io}"
        }
    },
    "api_keys": {
        "coingecko": "${COINGECKO_API_KEY:}",
        "cryptocompare": "${CRYPTOCOMPARE_API_KEY:}",
        "etherscan": "${ETHERSCAN_API_KEY:39DWNCE3KMSYBNM6DP8V6544I8IH5NQ4JP}",
        "bscscan": "${BSCSCAN_API_KEY:}",
        "polygonscan": "${POLYGONSCAN_API_KEY:}",
        "arbiscan": "${ARBISCAN_API_KEY:}",
        "optimism_etherscan": "${OPTIMISM_ETHERSCAN_API_KEY:}",
        "blockcypher": "${BLOCKCYPHER_API_KEY:}",
        "infura": "${INFURA_API_KEY:}",
        "alchemy": "${ALCHEMY_API_KEY:}",
        "getblock": "${GETBLOCK_API_KEY:}",
        "ankr": "${ANKR_API_KEY:}",
        "pocket": "${POKT_API_KEY:}",
        "quicknode": "${QUICKNODE_API_KEY:}"
    },
    "settings": {
        "max_retries": 5,
        "timeout": 60,
        "confirmation_blocks": {
            "ethereum": 12,
            "binance-smart-chain": 15,
            "bitcoin": 6,
            "polygon": 512,
            "arbitrum": 1,
            "optimism": 1,
            "default": 12
        },
        "gas_price_multiplier": 1.2,
        "max_gas_price_gwei": 200,
        "auto_update_rates": true,
        "fallback_to_public_nodes": true,
        "cache_ttl": 300,
        "health_check_interval": 60,
        "circuit_breaker": {
            "enabled": true,
            "failure_threshold": 5,
            "reset_timeout": 300
        },
        "logging": {
            "level": "info",
            "format": "json",
            "file": "logs/crosschain.log",
            "max_size_mb": 100,
            "backup_count": 7
        },
        "metrics": {
            "enabled": true,
            "port": 9090,
            "path": "/metrics"
        },
        "security": {
            "rate_limiting": {
                "enabled": true,
                "max_requests": 100,
                "time_window_seconds": 60
            },
            "whitelist_ips": [],
            "enable_auth": false,
            "auth_tokens": []
        }
    },
    "contracts": {
        "multicall": {
            "ethereum": "0xcA11bde05977b3631167028862bE2a173976CA11",
            "binance-smart-chain": "0x41263cba59eb80dc200f3e2544eda4ed6a90e76c",
            "polygon": "0x11ce4B23bD875D7F5C6a31084f55fDe1e9A87507",
            "arbitrum": "0x80C7DD17B01855a6D2347444a0FCC36136a314de",
            "optimism": "0x2DC0E2aa608532Da689e89e237dF582B783E552C"
        },
        "weth": {
            "ethereum": "0xC02aaA39b223FE8D0A0e5C4F27eAD9083C756Cc2",
            "binance-smart-chain": "0x2170ed0880ac9a755fd29b2688956bd959f933f8",
            "polygon": "0x7ceB23fD6bC0adD59E62ac25578270cFf1b9f619",
            "arbitrum": "0x82aF49447D8a07e3bd95BD0d56f35241523fBab1",
            "optimism": "0x4200000000000000000000000000000000000006"
        },
        "usdc": {
            "ethereum": "0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48",
            "binance-smart-chain": "0x8AC76a51cc950d9822D68b83fE1Ad97B32Cd580d",
            "polygon": "0x2791Bca1f2de4661ED88A30C99A7a9449Aa84174",
            "arbitrum": "0xFF970A61A04b1cA14834A43f5dE4533eBDDB5CC8",
            "optimism": "0x7F5c764cBc14f9669B88837ca1490cCa17c31607"
        }
    },
    "health_check": {
        "enabled": true,
        "interval_seconds": 300,
        "timeout_seconds": 30,
        "threshold_failures": 3,
        "notifications": {
            "enabled": true,
            "email": "${ALERT_EMAIL:}",
            "slack_webhook": "${SLACK_WEBHOOK_URL:}",
            "telegram_bot_token": "${TELEGRAM_BOT_TOKEN:}",
            "telegram_chat_id": "${TELEGRAM_CHAT_ID:}"
        }
    },
    "monitoring": {
        "prometheus": {
            "enabled": true,
            "port": 9090,
            "prefix": "crosschain_"
        },
        "sentry": {
            "enabled": false,
            "dsn": "${SENTRY_DSN:}",
            "environment": "${ENVIRONMENT:development}",
            "traces_sample_rate": 1.0
        },
        "datadog": {
            "enabled": false,
            "api_key": "${DATADOG_API_KEY:}",
            "app_key": "${DATADOG_APP_KEY:}",
            "env": "${ENVIRONMENT:development}"
        }
    }
}