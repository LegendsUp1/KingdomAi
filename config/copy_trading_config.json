        "use_stop_loss": true,
        "default_stop_loss_percent": 5,
        "use_take_profit": true,
        "default_take_profit_percent": 10,
        "use_trailing_stop": true,
        "trailing_stop_activation_percent": 2,
        "trailing_stop_callback_percent": 1
    },
    "position_sizing": {
        "method": "fixed_risk",
        "options": {
            "fixed_risk": {
                "risk_per_trade_percent": 1.5
