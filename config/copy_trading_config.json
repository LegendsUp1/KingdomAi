                "fraction_multiplier": 0.5,
                "max_fraction": 0.1
            },
            "fixed_ratio": {
                "base_position_size": 100,
                "delta": 500,
                "step_size": 1
            }
        }
    },
    "filtering": {
        "min_win_rate": 0.55,
        "min_profit_factor": 1.5,
        "min_trades_history": 100,
