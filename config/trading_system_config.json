            "z_score_threshold": 2.5,
            "asset_classes": ["STOCK", "FOREX", "COMMODITY"]
        },
        "yield_curve_strategy": {
            "enabled": true,
            "curve_inversion_threshold": -0.05,
            "duration_points": [2, 5, 10, 30],
            "asset_classes": ["BOND"],
            "instruments": ["US10Y", "US2Y", "US30Y", "US5Y", "BUND", "GILT"]
        },
        "volatility_surface": {
            "enabled": true,
            "vol_skew_threshold": 0.15,
            "term_structure_points": [30, 60, 90, 180],
            "asset_classes": ["OPTIONS"],
            "instruments": ["VIX", "SVXY", "SPX_OPTIONS", "QQQ_OPTIONS"]
        },
        "sentiment_analysis": {
            "enabled": true,
            "data_sources": ["news", "social_media", "earnings_calls"],
            "sentiment_threshold": 0.6,
            "asset_classes": ["STOCK", "CRYPTOCURRENCY", "FOREX"],
            "update_frequency_seconds": 300
        },
        "cross_asset_momentum": {
            "enabled": true,
            "lookback_periods": [20, 60, 120],
            "momentum_threshold": 0.05,
            "asset_classes": ["STOCK", "BOND", "FOREX", "COMMODITY", "CRYPTOCURRENCY"],
            "instruments": [
                "SPY", "QQQ", "IWM", "TLT", "GLD", "SLV", "USO", 
                "EUR/USD", "GBP/USD", "USD/JPY", "BTC/USD", "ETH/USD"
            ]
        },
        "liquidity_provision": {
            "enabled": true,
            "max_spread": 0.005,
            "min_depth": 100000,
            "rebalance_threshold": 0.02,
            "asset_classes": ["STOCK", "CRYPTOCURRENCY", "FOREX"],
            "instruments": ["AAPL", "MSFT", "BTC/USD", "ETH/USD", "EUR/USD"]
        },
        "earnings_volatility": {
            "enabled": true,
            "pre_earnings_days": 5,
            "post_earnings_days": 3,
            "volatility_increase_threshold": 1.5,
            "asset_classes": ["STOCK", "OPTIONS"],
            "market_cap_min": 1000000000
