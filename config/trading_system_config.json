    "exchanges": {
        "binance": {
            "enabled": true,
            "pairs": ["BTC/USDT", "ETH/USDT", "SOL/USDT", "BNB/USDT"],
            "asset_classes": ["CRYPTOCURRENCY"],
            "market_types": ["SPOT", "FUTURES", "MARGIN", "OPTIONS"]
        }
    }
