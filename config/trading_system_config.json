{
    "enabled": true,
    "log_level": "INFO",
    "auto_trading": true,
    "market_api": "multi_market_api",
    "risk_management": {
        "max_open_positions": 15,
        "max_position_size": 0.1,
        "stop_loss_required": true,
        "default_stop_loss_pct": 0.05,
        "max_daily_drawdown": 0.03,
        "max_risk_per_trade": 0.02,
        "cross_asset_exposure_limit": 0.25,
        "volatility_based_sizing": true,
        "market_correlation_monitoring": true,
        "circuit_breakers": {
            "enabled": true,
            "max_drawdown_trigger": 0.08,
            "volatility_spike_trigger": 3.0,
            "liquidity_threshold": 0.4
        }
    },
    "redis_quantum_nexus": {
        "host": "localhost",
        "port": 6380,
        "password": "QuantumNexus2025",
        "allow_fallback": false,
        "health_check_interval_seconds": 30,
        "halt_on_failure": true,
        "persistent_storage": true
    },
    "connection_verification": {
        "enabled": true,
        "verify_on_startup": true,
        "verify_interval_seconds": 60,
        "timeout_seconds": 10,
        "required_connections": ["redis", "websocket", "blockchain", "api_key"],
        "halt_on_failure": true
    },
    "strategies": {
        "moving_average_crossover": {
            "enabled": true,
            "fast_ma": 9,
            "slow_ma": 21,
            "signal_threshold": 0.0,
            "pairs": ["BTC/USDT", "ETH/USDT"],
            "asset_classes": ["CRYPTOCURRENCY"]
        },
        "rsi": {
            "enabled": true,
            "period": 14,
            "overbought": 70,
            "oversold": 30,
            "pairs": ["BTC/USDT", "ETH/USDT"],
            "asset_classes": ["CRYPTOCURRENCY"]
        },
        "macd": {
            "enabled": true,
            "fast_period": 12,
            "slow_period": 26,
            "signal_period": 9,
            "pairs": ["BTC/USDT", "ETH/USDT"],
            "asset_classes": ["CRYPTOCURRENCY"]
        },
        "mean_reversion": {
            "enabled": true,
            "lookback_period": 20,
            "z_score_threshold": 2.0,
            "asset_classes": ["STOCK", "ETF", "FOREX"],
            "pairs": ["AAPL/USD", "MSFT/USD", "GOOGL/USD", "EUR/USD", "GBP/USD", "SPY/USD"]
        },
        "statistical_arbitrage": {
            "enabled": true,
            "pairs": ["AAPL/MSFT", "GOOGL/META", "GLD/SLV", "EUR/USD/JPY"],
