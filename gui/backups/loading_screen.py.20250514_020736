            elif status == "error":
                self.redis_status_var.set(f"Redis Nexus: Error! ({message})")
                logger.error(f"Redis Quantum Nexus connection error: {message}")
                self.add_component_log(f" Redis Quantum Nexus error: {message}")
            else:
                self.redis_status_var.set(f"Redis Nexus: {status.title()} ({message})")
                logger.info(f"Redis Quantum Nexus status: {status} - {message}")
