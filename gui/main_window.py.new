            address_text = address_var.get() if address_var else "Address not available"
            
            # Display address
            address_display = ttk.Entry(address_frame, width=50)
            address_display.pack(fill=tk.X, padx=10, pady=5)
            address_display.insert(0, address_text)
            address_display.configure(state="readonly")
            
            # Copy button
            copy_button = ttk.Button(address_frame, text="Copy Address", 
                                    command=lambda: self._copy_to_clipboard(address_text))
            copy_button.pack(padx=10, pady=5)
            
            # QR code placeholder (simulate with a frame)
            qr_frame = ttk.Frame(receive_window, width=150, height=150, style="QR.TFrame")
            qr_frame.pack(padx=10, pady=10)
            
            # Note about QR code
            note_label = ttk.Label(receive_window, text="QR Code would be displayed here")
            note_label.pack(padx=10, pady=5)
            
            # Close button
            close_button = ttk.Button(receive_window, text="Close", command=receive_window.destroy)
            close_button.pack(padx=10, pady=10)
            
        except Exception as e:
            self.logger.error(f"Error showing receive dialog: {e}")
            self.logger.error(traceback.format_exc())
            
    def _search_blockchain(self, network: str, query: str) -> None:
        """Search blockchain for address, transaction, or block."""
        try:
            if not query:
                messagebox.showwarning("Empty Query", "Please enter an address, transaction hash, or block number")
                return
                
            # Get explorer text widget
            explorer_text = self.widget_registry.get_widget("blockchain_explorer")
            if not explorer_text:
                return
                
            # Update display
            explorer_text.configure(state=tk.NORMAL)
            explorer_text.delete(1.0, tk.END)
            explorer_text.insert(tk.END, f"Searching {network} for: {query}\n\nPlease wait...")
            explorer_text.configure(state=tk.DISABLED)
            
            # Publish search event
            self.event_bus.publish("blockchain.search", {
                "network": network,
                "query": query
            })
            
        except Exception as e:
            self.logger.error(f"Error searching blockchain: {e}")
            messagebox.showerror("Search Error", f"Failed to search blockchain: {str(e)}")
            
    def _handle_balance_update(self, event_data: Dict[str, Any]) -> None:
        """Handle wallet balance updates."""
        try:
            # Get balance data
            balance = event_data.get("balance", 0.0)
            currency = event_data.get("currency", "ETH")
            address = event_data.get("address", "")
            
            # Update display widgets
            balance_var = self.widget_registry.get_widget("blockchain_balance")
            if balance_var:
                balance_var.set(f"{balance:.8f} {currency}")
                
            address_var = self.widget_registry.get_widget("blockchain_address")
            if address_var and address:
                address_var.set(address)
                
        except Exception as e:
            self.logger.error(f"Error handling balance update: {e}")
            
    def _handle_tx_update(self, event_data: Dict[str, Any]) -> None:
        """Handle transaction updates."""
        try:
            # Get transaction list
            tx_list = self.widget_registry.get_widget("blockchain_tx_list")
            if not tx_list:
                return
                
            # Clear existing items
            for item in tx_list.get_children():
                tx_list.delete(item)
                
            # Add new transaction data
            transactions = event_data.get("transactions", [])
            for tx in transactions:
                tx_list.insert("", tk.END, values=(
                    tx.get("date", ""),
                    tx.get("type", ""),
                    f"{tx.get('amount', 0.0)} {tx.get('currency', 'ETH')}",
                    tx.get("status", "")
                ))
                
        except Exception as e:
            self.logger.error(f"Error handling transaction update: {e}")
            
    def _handle_blockchain_search_result(self, event_data: Dict[str, Any]) -> None:
        """Handle blockchain search results."""
        try:
            # Get explorer text widget
            explorer_text = self.widget_registry.get_widget("blockchain_explorer")
            if not explorer_text:
                return
                
            # Get result data
            result = event_data.get("result", "No results found")
            error = event_data.get("error", None)
            
            # Update display
            explorer_text.configure(state=tk.NORMAL)
            explorer_text.delete(1.0, tk.END)
            
            if error:
                explorer_text.insert(tk.END, f"Error: {error}")
            else:
                explorer_text.insert(tk.END, result)
                
            explorer_text.configure(state=tk.DISABLED)
            
        except Exception as e:
            self.logger.error(f"Error handling blockchain search result: {e}")
    
    async def _start_live_data_refresh(self) -> None:
        """Start live data refresh for market data, balance, etc."""
        try:
            # Request initial data
            await self.event_bus.publish("market.request_data", {})
            await self.event_bus.publish("wallet.request_data", {})
            await self.event_bus.publish("mining.request_status", {})
            await self.event_bus.publish("api.key.request_status", {})
            
            # Set up periodic refresh tasks
            asyncio.create_task(self._periodic_market_data_refresh())
            asyncio.create_task(self._periodic_wallet_data_refresh())
            asyncio.create_task(self._periodic_mining_status_refresh())
            
            self.logger.info("Started live data refresh")
        except Exception as e:
            self.logger.error(f"Error starting live data refresh: {e}")
            self.logger.error(traceback.format_exc())
    
    async def _periodic_market_data_refresh(self) -> None:
        """Periodically refresh market data."""
        try:
            while True:
                await asyncio.sleep(30)  # Refresh every 30 seconds
                await self.event_bus.publish("market.request_data", {})
        except Exception as e:
            self.logger.error(f"Error in periodic market data refresh: {e}")
            self.logger.error(traceback.format_exc())
    
    async def _periodic_wallet_data_refresh(self) -> None:
        """Periodically refresh wallet data."""
        try:
            while True:
                await asyncio.sleep(60)  # Refresh every 60 seconds
                await self.event_bus.publish("wallet.request_data", {})
        except Exception as e:
            self.logger.error(f"Error in periodic wallet data refresh: {e}")
            self.logger.error(traceback.format_exc())
    
    async def _periodic_mining_status_refresh(self) -> None:
        """Periodically refresh mining status."""
        try:
            while True:
                await asyncio.sleep(15)  # Refresh every 15 seconds
                await self.event_bus.publish("mining.request_status", {})
        except Exception as e:
            self.logger.error(f"Error in periodic mining status refresh: {e}")
            self.logger.error(traceback.format_exc())
    
    def _handle_price_update(self, event_data: Dict[str, Any]) -> None:
        """Handle market price updates."""
        try:
            # Get price data
            symbol = event_data.get("symbol", "")
            price = event_data.get("price", 0.0)
            change = event_data.get("change_24h", 0.0)
            
            # Update display widgets
            if symbol == "BTC":
                btc_price_var = self.widget_registry.get_widget("btc_price")
                if btc_price_var:
                    btc_price_var.set(f"${price:,.2f}")
                    
                btc_change_var = self.widget_registry.get_widget("btc_change")
                if btc_change_var:
                    btc_change_var.set(f"{change:+.2f}%")
                    
            elif symbol == "ETH":
                eth_price_var = self.widget_registry.get_widget("eth_price")
                if eth_price_var:
                    eth_price_var.set(f"${price:,.2f}")
                    
                eth_change_var = self.widget_registry.get_widget("eth_change")
                if eth_change_var:
                    eth_change_var.set(f"{change:+.2f}%")
            
            # Update order book if available
            order_book = event_data.get("order_book", None)
            if order_book and symbol:
                self._update_order_book(symbol, order_book)
                
        except Exception as e:
            self.logger.error(f"Error handling price update: {e}")
            self.logger.error(traceback.format_exc())
    
    def _update_order_book(self, symbol: str, order_book: Dict[str, Any]) -> None:
        """Update the order book display."""
        try:
            # Get order book widgets
            bids_tree = self.widget_registry.get_widget(f"{symbol.lower()}_bids")
            asks_tree = self.widget_registry.get_widget(f"{symbol.lower()}_asks")
            
            if not bids_tree or not asks_tree:
                return
                
            # Clear existing items
            for tree in [bids_tree, asks_tree]:
                for item in tree.get_children():
                    tree.delete(item)
                    
            # Add bid orders
            bids = order_book.get("bids", [])
            for i, bid in enumerate(bids[:10]):  # Show top 10 bids
                price = bid.get("price", 0.0)
                amount = bid.get("amount", 0.0)
                total = price * amount
                
                bids_tree.insert("", tk.END, values=(f"${price:,.2f}", f"{amount:.4f}", f"${total:,.2f}"))
                
            # Add ask orders
            asks = order_book.get("asks", [])
            for i, ask in enumerate(asks[:10]):  # Show top 10 asks
                price = ask.get("price", 0.0)
                amount = ask.get("amount", 0.0)
                total = price * amount
                
                asks_tree.insert("", tk.END, values=(f"${price:,.2f}", f"{amount:.4f}", f"${total:,.2f}"))
                
        except Exception as e:
            self.logger.error(f"Error updating order book: {e}")
    
    def _handle_mining_update(self, event_data: Dict[str, Any]) -> None:
        """Handle mining status updates."""
        try:
            # Update mining status widgets
            status = event_data.get("status", "Stopped")
            hashrate = event_data.get("hashrate", 0.0)
            shares = event_data.get("shares", 0)
            accepted = event_data.get("accepted", 0)
            rejected = event_data.get("rejected", 0)
            temperature = event_data.get("temperature", 0.0)
            
            # Update status label
            status_var = self.widget_registry.get_widget("mining_status")
            if status_var:
                status_var.set(status)
                
            # Update hashrate
            hashrate_var = self.widget_registry.get_widget("mining_hashrate")
            if hashrate_var:
                hashrate_unit = "H/s"
                if hashrate >= 1000000000:
                    hashrate = hashrate / 1000000000
                    hashrate_unit = "GH/s"
                elif hashrate >= 1000000:
                    hashrate = hashrate / 1000000
                    hashrate_unit = "MH/s"
                elif hashrate >= 1000:
                    hashrate = hashrate / 1000
                    hashrate_unit = "KH/s"
                    
                hashrate_var.set(f"{hashrate:.2f} {hashrate_unit}")
                
            # Update shares
            shares_var = self.widget_registry.get_widget("mining_shares")
            if shares_var:
                shares_var.set(f"{shares} ({accepted} accepted, {rejected} rejected)")
                
            # Update temperature
            temp_var = self.widget_registry.get_widget("mining_temperature")
            if temp_var:
                temp_var.set(f"{temperature}°C")
                
            # Update mining history chart if available
            history = event_data.get("history", [])
            if history:
                self._update_mining_chart(history)
                
        except Exception as e:
            self.logger.error(f"Error handling mining update: {e}")
            self.logger.error(traceback.format_exc())
    
    def _update_mining_chart(self, history: List[Dict[str, Any]]) -> None:
        """Update the mining history chart."""
        # In a real implementation, this would update a chart widget
        # For now, we'll just log the update
        self.logger.debug(f"Updated mining chart with {len(history)} data points")
    
    def _handle_ai_response(self, event_data: Dict[str, Any]) -> None:
        """Handle AI response events."""
        try:
            # Get response data
            response = event_data.get("response", "")
            query_id = event_data.get("query_id", "")
            
            # Get chat widget
            chat_text = self.widget_registry.get_widget("ai_chat")
            if not chat_text:
                return
                
            # Update chat display
            chat_text.configure(state=tk.NORMAL)
            chat_text.insert(tk.END, f"\nThothAI: {response}\n")
            chat_text.see(tk.END)  # Scroll to bottom
            chat_text.configure(state=tk.DISABLED)  # Make read-only again
            
        except Exception as e:
            self.logger.error(f"Error handling AI response: {e}")
            self.logger.error(traceback.format_exc())
    
    def _handle_ai_status(self, event_data: Dict[str, Any]) -> None:
        """Handle AI status updates."""
        try:
            # Get status data
            status = event_data.get("status", "Disconnected")
            model = event_data.get("model", "Unknown")
            
            # Update status widgets
            status_var = self.widget_registry.get_widget("ai_status")
            if status_var:
                status_var.set(f"Status: {status}")
                
            model_var = self.widget_registry.get_widget("ai_model")
            if model_var:
                model_var.set(f"Model: {model}")
                
        except Exception as e:
            self.logger.error(f"Error handling AI status update: {e}")
            self.logger.error(traceback.format_exc())
    
    def _handle_code_generation(self, event_data: Dict[str, Any]) -> None:
        """Handle code generation events."""
        try:
            # Get code data
            code = event_data.get("code", "")
            language = event_data.get("language", "python")
            description = event_data.get("description", "Generated code")
            
            # Get code display widget
            code_text = self.widget_registry.get_widget("ai_code")
            if not code_text:
                return
                
            # Update code display
            code_text.configure(state=tk.NORMAL)
            code_text.delete(1.0, tk.END)  # Clear existing code
            code_text.insert(tk.END, f"# {description}\n")
            code_text.insert(tk.END, code)
            code_text.configure(state=tk.DISABLED)  # Make read-only
            
        except Exception as e:
            self.logger.error(f"Error handling code generation: {e}")
            self.logger.error(traceback.format_exc())
    
    def _handle_voice_command(self, event_data: Dict[str, Any]) -> None:
        """Handle voice command events."""
        try:
            # Get command data
            command = event_data.get("command", "")
            confidence = event_data.get("confidence", 0.0)
            
            if not command:
                return
                
            # Get chat widget
            chat_text = self.widget_registry.get_widget("ai_chat")
            if not chat_text:
                return
                
            # Update chat display with voice command
            chat_text.configure(state=tk.NORMAL)
            chat_text.insert(tk.END, f"\nVoice Command: {command}\n")
            chat_text.see(tk.END)  # Scroll to bottom
            
            # Send command to AI
            asyncio.create_task(self.event_bus.publish("thoth.query", {
                "query": command,
                "source": "voice"
            }))
            
            chat_text.configure(state=tk.DISABLED)  # Make read-only again
            
        except Exception as e:
            self.logger.error(f"Error handling voice command: {e}")
            self.logger.error(traceback.format_exc())
    
    def _handle_api_key_status(self, event_data: Dict[str, Any]) -> None:
        """Handle API key status updates."""
        try:
            # Get API key data
            service = event_data.get("service", "")
            key = event_data.get("key", "")
            status = event_data.get("status", "Unknown")
            
            # Get API list widget
            api_list = self.widget_registry.get_widget("api_list")
            if not api_list:
                return
                
            # Check if service already exists in list
            found = False
            for item in api_list.get_children():
                if api_list.item(item, "values")[0] == service:
                    # Update existing item
                    api_list.item(item, values=(service, self._mask_api_key(key), status))
                    found = True
                    break
                    
            # Add new item if not found
            if not found:
                api_list.insert("", tk.END, values=(service, self._mask_api_key(key), status))
                
        except Exception as e:
            self.logger.error(f"Error handling API key status update: {e}")
            self.logger.error(traceback.format_exc())
    
    def _mask_api_key(self, key: str) -> str:
        """Mask API key for display."""
        if not key:
            return ""
            
        if len(key) <= 8:
            return "*" * len(key)
            
        return key[:4] + "*" * (len(key) - 8) + key[-4:]
    
    def _handle_api_test_result(self, event_data: Dict[str, Any]) -> None:
        """Handle API test results."""
        try:
            # Get test result data
            service = event_data.get("service", "")
            success = event_data.get("success", False)
            message = event_data.get("message", "")
            
            # Show result message
            if success:
                messagebox.showinfo(f"{service} API Connection", 
                                  f"Connection successful: {message}")
            else:
                messagebox.showerror(f"{service} API Connection", 
                                   f"Connection failed: {message}")
                
        except Exception as e:
            self.logger.error(f"Error handling API test result: {e}")
            self.logger.error(traceback.format_exc())

    def _connect_event_handlers(self) -> None:
        """Connect event handlers to the event bus."""
        try:
            # Market data events
            self.event_bus.subscribe("market.price_update", self._handle_price_update)
            self.event_bus.subscribe("wallet.balance_update", self._handle_balance_update)
            self.event_bus.subscribe("wallet.transaction_update", self._handle_tx_update)
            self.event_bus.subscribe("mining.status_update", self._handle_mining_update)
            
            # AI related events
            self.event_bus.subscribe("thoth.response", self._handle_ai_response)
            self.event_bus.subscribe("thoth.status.update", self._handle_ai_status)
            self.event_bus.subscribe("thoth.code_generated", self._handle_code_generation)
            
            # Voice system events
            self.event_bus.subscribe("voice.command", self._handle_voice_command)
            
            # API and system events
            self.event_bus.subscribe("api.key.status", self._handle_api_key_status)
            self.event_bus.subscribe("api.test.result", self._handle_api_test_result)
            self.event_bus.subscribe("blockchain.search_result", self._handle_blockchain_search_result)
            
            self.logger.info("Event handlers connected")
        except Exception as e:
            self.logger.error(f"Error connecting event handlers: {e}")
            self.logger.error(traceback.format_exc())
