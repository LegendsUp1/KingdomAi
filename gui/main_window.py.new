            self.logger.error(traceback.format_exc())
            
    def _submit_order(self, market: str, side: str, order_type: str, price: str, amount: str) -> None:
        """Submit a trading order through the event bus."""
        try:
            # Validate inputs
            if order_type == "Limit" and (not price or float(price) <= 0):
                messagebox.showerror("Invalid Order", "Please enter a valid price")
                return
                
            if not amount or float(amount) <= 0:
                messagebox.showerror("Invalid Order", "Please enter a valid amount")
                return
                
            # Prepare order data
            order_data = {
                "market": market,
                "side": side.lower(),
                "type": order_type.lower(),
                "price": float(price) if price else None,
                "amount": float(amount),
                "timestamp": datetime.now().isoformat()
            }
            
            # Publish order event
            self.event_bus.publish("trading.place_order", order_data)
            
            # Show confirmation
            messagebox.showinfo("Order Submitted", f"{side} order for {amount} {market.split('/')[0]} submitted")
            
        except ValueError as e:
            messagebox.showerror("Input Error", f"Invalid number format: {str(e)}")
        except Exception as e:
            self.logger.error(f"Error submitting order: {e}")
            messagebox.showerror("Order Error", f"Failed to submit order: {str(e)}")
            
    def _show_trading_strategies(self) -> None:
        """Show the trading strategies dialog."""
        try:
            strategies_window = tk.Toplevel(self.root)
            strategies_window.title("Trading Strategies")
            strategies_window.geometry("600x400")
            strategies_window.grab_set()  # Make window modal
            
            # Create the content
            header_label = ttk.Label(strategies_window, text="Available Trading Strategies", style="Header.TLabel")
            header_label.pack(padx=10, pady=10)
            
            # Create strategies list
            strategies_frame = ttk.Frame(strategies_window)
            strategies_frame.pack(fill=tk.BOTH, expand=True, padx=10, pady=5)
            
            strategies_list = [
                ("DCA Bot", "Dollar Cost Averaging automatic buying", False),
                ("MACD Crossover", "Moving Average Convergence Divergence strategy", False),
                ("RSI Reversal", "Relative Strength Index reversal detection", False),
                ("Grid Trading", "Automated grid trading strategy", False),
                ("Moonshot", "High-risk moonshot strategy for new tokens", False),
                ("Whale Tracker", "Follow large wallet transactions", False)
            ]
            
            for i, (name, description, active) in enumerate(strategies_list):
                strategy_frame = ttk.Frame(strategies_frame)
                strategy_frame.pack(fill=tk.X, padx=5, pady=2)
                
                var = tk.BooleanVar(value=active)
                check = ttk.Checkbutton(strategy_frame, text=name, variable=var)
                check.pack(side=tk.LEFT, padx=5)
                
                desc_label = ttk.Label(strategy_frame, text=description)
                desc_label.pack(side=tk.LEFT, padx=10)
                
                config_button = ttk.Button(strategy_frame, text="Configure",
                                           command=lambda s=name: self._configure_strategy(s))
                config_button.pack(side=tk.RIGHT, padx=5)
                
            # Buttons at bottom
            button_frame = ttk.Frame(strategies_window)
            button_frame.pack(fill=tk.X, padx=10, pady=10)
            
            apply_button = ttk.Button(button_frame, text="Apply", 
                                      command=strategies_window.destroy)
            apply_button.pack(side=tk.RIGHT, padx=5)
            
            cancel_button = ttk.Button(button_frame, text="Cancel", 
                                       command=strategies_window.destroy)
            cancel_button.pack(side=tk.RIGHT, padx=5)
            
        except Exception as e:
            self.logger.error(f"Error showing strategies dialog: {e}")
            self.logger.error(traceback.format_exc())
            
    def _configure_strategy(self, strategy_name: str) -> None:
        """Show configuration dialog for a specific trading strategy."""
        try:
            messagebox.showinfo("Strategy Configuration", 
                               f"Configuration for {strategy_name} would be shown here.\n\nThis will be implemented in the next phase.")
        except Exception as e:
            self.logger.error(f"Error configuring strategy {strategy_name}: {e}")
            messagebox.showerror("Configuration Error", f"Failed to configure strategy: {str(e)}")
            
