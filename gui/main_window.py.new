            ai_status_label.pack(side=tk.LEFT, padx=5)
            
            # Voice controls
            voice_frame = ttk.LabelFrame(control_frame, text="Voice Controls")
            voice_frame.pack(fill=tk.X, padx=5, pady=5)
            
            # Voice toggle
            voice_toggle_frame = ttk.Frame(voice_frame)
            voice_toggle_frame.pack(fill=tk.X, padx=5, pady=5)
            
            voice_enabled_var = tk.BooleanVar(value=False)
            voice_checkbox = ttk.Checkbutton(voice_toggle_frame, text="Enable Voice", variable=voice_enabled_var,
                                            command=self._toggle_voice)
            voice_checkbox.pack(side=tk.LEFT, padx=5)
            
            # Voice type selection
            voice_type_frame = ttk.Frame(voice_frame)
            voice_type_frame.pack(fill=tk.X, padx=5, pady=5)
            
            ttk.Label(voice_type_frame, text="Voice:").pack(side=tk.LEFT, padx=5)
            voice_type_var = tk.StringVar(value="Default")
            voice_type_combo = ttk.Combobox(voice_type_frame, textvariable=voice_type_var, 
                                          values=["Default", "Black Panther"], state="disabled")
            voice_type_combo.pack(side=tk.LEFT, fill=tk.X, expand=True, padx=5)
            
            # Register voice widgets
            self.widget_registry.register_widget("voice_enabled", voice_enabled_var)
            self.widget_registry.register_widget("voice_type", voice_type_combo)
            
            # Test voice button
            test_voice_button = ttk.Button(voice_frame, text="Test Voice", 
                                         command=self._test_voice, state="disabled")
            test_voice_button.pack(fill=tk.X, padx=5, pady=5)
            self.widget_registry.register_widget("test_voice_button", test_voice_button)
            
            # Code generation section
            code_frame = ttk.LabelFrame(control_frame, text="Code Generation")
            code_frame.pack(fill=tk.X, padx=5, pady=5, expand=True)
            
            # Output format
            format_frame = ttk.Frame(code_frame)
            format_frame.pack(fill=tk.X, padx=5, pady=5)
            
            ttk.Label(format_frame, text="Format:").pack(side=tk.LEFT, padx=5)
            format_var = tk.StringVar(value="Python")
            format_combo = ttk.Combobox(format_frame, textvariable=format_var, 
                                       values=["Python", "JavaScript", "Java", "C++", "Bash", "Markdown"])
            format_combo.pack(side=tk.LEFT, fill=tk.X, expand=True, padx=5)
            
            # Generate button
            generate_button = ttk.Button(code_frame, text="Generate Code", 
                                       command=lambda: self._generate_code(format_var.get()))
            generate_button.pack(fill=tk.X, padx=5, pady=10)
            
            # Input area (bottom panel)
            input_frame = ttk.Frame(bottom_panel)
            input_frame.pack(fill=tk.X, expand=True, side=tk.LEFT, padx=5, pady=5)
            
            self.message_input = tk.Text(input_frame, height=3, width=40, wrap=tk.WORD)
            self.message_input.pack(fill=tk.X, expand=True, side=tk.LEFT)
            self.message_input.bind("<Return>", self._on_enter_pressed)
            
            # Send button
            send_button = ttk.Button(bottom_panel, text="Send", command=self._send_message)
            send_button.pack(side=tk.RIGHT, padx=5, pady=5)
            
            # Voice input button
            voice_input_button = ttk.Button(bottom_panel, text="🎤", width=3, 
                                         command=self._start_voice_input, state="disabled")
            voice_input_button.pack(side=tk.RIGHT, padx=5, pady=5)
            self.widget_registry.register_widget("voice_input_button", voice_input_button)
            
            # Register widgets for updates
            self.widget_registry.register_widget("ai_status", ai_status_var)
            self.widget_registry.register_widget("chat_history", self.chat_history)
            self.widget_registry.register_widget("ai_model", model_var)
            
            # Initialize AI connection status
            self.event_bus.publish("thoth.status.request", {})
            
            self.logger.info("AI tab setup complete")
        except Exception as e:
            self.logger.error(f"Error setting up AI tab: {e}")
            self.logger.error(traceback.format_exc())
            
    def _toggle_voice(self) -> None:
        """Toggle voice system on/off."""
        try:
            voice_enabled = self.widget_registry.get_widget("voice_enabled").get()
            voice_type_combo = self.widget_registry.get_widget("voice_type")
            test_voice_button = self.widget_registry.get_widget("test_voice_button")
            voice_input_button = self.widget_registry.get_widget("voice_input_button")
            
            # Enable/disable controls
            voice_type_combo.configure(state="readonly" if voice_enabled else "disabled")
            test_voice_button.configure(state="normal" if voice_enabled else "disabled")
            voice_input_button.configure(state="normal" if voice_enabled else "disabled")
            
            # Publish event to voice system
            self.event_bus.publish("voice.set", {"enabled": voice_enabled})
            
            # Log action
            action = "enabled" if voice_enabled else "disabled"
            self.logger.info(f"Voice system {action}")
            
        except Exception as e:
            self.logger.error(f"Error toggling voice: {e}")
            messagebox.showerror("Voice Error", f"Failed to toggle voice: {str(e)}")
            
    def _test_voice(self) -> None:
        """Test the voice system with a sample message."""
        try:
            voice_type = self.widget_registry.get_widget("voice_type").get()
            self.event_bus.publish("voice.speak", {
                "text": "This is a test of the Kingdom AI voice system.", 
                "voice_type": voice_type
            })
        except Exception as e:
            self.logger.error(f"Error testing voice: {e}")
            messagebox.showerror("Voice Error", f"Failed to test voice: {str(e)}")
            
    def _on_enter_pressed(self, event: tk.Event) -> None:
        """Handle Enter key press in the message input."""
        if not (event.state & 0x1):  # No Shift key
            self._send_message()
            return "break"  # Prevent default Enter behavior
        return None
    
    def _send_message(self) -> None:
        """Send a message to ThothAI through the event bus."""
        try:
            # Get message text
            message = self.message_input.get("1.0", tk.END).strip()
            if not message:
                return
                
            # Clear input
            self.message_input.delete("1.0", tk.END)
            
            # Update chat history
            self.chat_history.configure(state=tk.NORMAL)
            self.chat_history.insert(tk.END, f"You: {message}\n\n")
            self.chat_history.insert(tk.END, "ThothAI: Thinking...\n\n")
            self.chat_history.see(tk.END)
            self.chat_history.configure(state=tk.DISABLED)
            
            # Get AI model
            model = self.widget_registry.get_widget("ai_model").get()
            
            # Prepare request data
            request_data = {
                "message": message,
                "model": model,
                "request_id": str(int(time.time() * 1000)),  # Simple unique ID
                "timestamp": datetime.now().isoformat()
            }
            
            # Publish request event
            self.event_bus.publish("thoth.request", request_data)
            
        except Exception as e:
            self.logger.error(f"Error sending message: {e}")
            messagebox.showerror("Message Error", f"Failed to send message: {str(e)}")
            
    def _generate_code(self, format_type: str) -> None:
        """Request code generation from ThothAI."""
        try:
            # Get message text
            prompt = self.message_input.get("1.0", tk.END).strip()
            if not prompt:
                messagebox.showwarning("Code Generation", "Please enter a description for the code you want to generate.")
                return
                
            # Clear input
            self.message_input.delete("1.0", tk.END)
            
            # Update chat history
            self.chat_history.configure(state=tk.NORMAL)
            self.chat_history.insert(tk.END, f"You: [CODE REQUEST] {prompt}\n\n")
            self.chat_history.insert(tk.END, "ThothAI: Generating code...\n\n")
            self.chat_history.see(tk.END)
            self.chat_history.configure(state=tk.DISABLED)
            
            # Prepare request data
            request_data = {
                "prompt": prompt,
                "format": format_type,
                "request_id": str(int(time.time() * 1000)),  # Simple unique ID
                "timestamp": datetime.now().isoformat()
            }
            
            # Publish request event
            self.event_bus.publish("thoth.generate_code", request_data)
            
        except Exception as e:
            self.logger.error(f"Error requesting code generation: {e}")
            messagebox.showerror("Code Generation Error", f"Failed to request code: {str(e)}")
            
    def _start_voice_input(self) -> None:
        """Start voice input for message."""
        try:
            # Visual feedback
            self.message_input.delete("1.0", tk.END)
            self.message_input.insert(tk.END, "Listening...")
            
            # Publish voice listen event
            self.event_bus.publish("voice.listen", {"mode": "command"})
            
        except Exception as e:
            self.logger.error(f"Error starting voice input: {e}")
            messagebox.showerror("Voice Input Error", f"Failed to start voice input: {str(e)}")
            
    def _handle_voice_command(self, event_data: Dict[str, Any]) -> None:
        """Handle a voice command received from the voice system."""
        try:
            # Get command text
            command = event_data.get("text", "")
            if not command:
                self.message_input.delete("1.0", tk.END)
                return
                
            # Update input field
            self.message_input.delete("1.0", tk.END)
            self.message_input.insert(tk.END, command)
            
            # Automatically send if configured to do so
            auto_send = event_data.get("auto_send", False)
            if auto_send:
                self._send_message()
                
        except Exception as e:
            self.logger.error(f"Error handling voice command: {e}")
            
    def _handle_ai_response(self, event_data: Dict[str, Any]) -> None:
        """Handle a response from ThothAI."""
        try:
            # Get response text and metadata
            response = event_data.get("response", "")
            request_id = event_data.get("request_id", "")
            error = event_data.get("error", None)
            
            # Update chat history
            self.chat_history.configure(state=tk.NORMAL)
            
            # Find and remove the "Thinking..." placeholder
            text = self.chat_history.get("1.0", tk.END)
            if "ThothAI: Thinking..." in text:
                start = text.rfind("ThothAI: Thinking...")
                end = start + len("ThothAI: Thinking...\n\n")
                self.chat_history.delete(f"1.0 + {start}c", f"1.0 + {end}c")
            
            # Add the actual response
            if error:
                self.chat_history.insert(tk.END, f"ThothAI: [ERROR] {error}\n\n")
            else:
                self.chat_history.insert(tk.END, f"ThothAI: {response}\n\n")
                
                # If voice is enabled, speak the response
                voice_enabled = self.widget_registry.get_widget("voice_enabled").get()
                if voice_enabled:
                    voice_type = self.widget_registry.get_widget("voice_type").get()
                    self.event_bus.publish("voice.speak", {
                        "text": response, 
                        "voice_type": voice_type
                    })
            
            self.chat_history.see(tk.END)
            self.chat_history.configure(state=tk.DISABLED)
            
        except Exception as e:
            self.logger.error(f"Error handling AI response: {e}")
            
    def _handle_code_generation(self, event_data: Dict[str, Any]) -> None:
        """Handle code generation results from ThothAI."""
        try:
            # Get generated code and metadata
            code = event_data.get("code", "")
            language = event_data.get("language", "")
            error = event_data.get("error", None)
            
            # Update chat history
            self.chat_history.configure(state=tk.NORMAL)
            
            # Find and remove the "Generating code..." placeholder
            text = self.chat_history.get("1.0", tk.END)
            if "ThothAI: Generating code..." in text:
                start = text.rfind("ThothAI: Generating code...")
                end = start + len("ThothAI: Generating code...\n\n")
                self.chat_history.delete(f"1.0 + {start}c", f"1.0 + {end}c")
            
            # Add the actual response
            if error:
                self.chat_history.insert(tk.END, f"ThothAI: [ERROR] {error}\n\n")
            else:
                self.chat_history.insert(tk.END, f"ThothAI: Here's the {language} code you requested:\n\n```{language}\n{code}\n```\n\n")
            
            self.chat_history.see(tk.END)
            self.chat_history.configure(state=tk.DISABLED)
            
        except Exception as e:
            self.logger.error(f"Error handling code generation: {e}")
            
    def _handle_ai_status(self, event_data: Dict[str, Any]) -> None:
        """Handle AI status updates."""
        try:
            # Get status information
            status = event_data.get("status", "Unknown")
            model = event_data.get("model", "Unknown")
            connected = event_data.get("connected", False)
            
            # Update status display
            status_var = self.widget_registry.get_widget("ai_status")
            if connected:
                status_var.set(f"Connected ({model})")
            else:
                status_var.set(f"Disconnected: {status}")
                
            # Update model if provided
            if model and model != "Unknown":
                model_var = self.widget_registry.get_widget("ai_model")
                current = model_var.get()
                if "Ollama" not in current and "Fallback" not in current:
                    model_var.set(f"Ollama ({model})")
                    
        except Exception as e:
            self.logger.error(f"Error handling AI status: {e}")
            
    def _setup_ui(self) -> None:
        """Set up the user interface components."""
        try:
            # Create theme styles
            self._create_styles()
            
            # Create notebook for tabs
            self.notebook = ttk.Notebook(self.root)
            self.notebook.pack(fill=tk.BOTH, expand=True, padx=10, pady=10)
            
            # Set up widget registry
            self.widget_registry = WidgetRegistry()
            
            # Set up each tab
            self._setup_dashboard_tab()
            self._setup_trading_tab()
            self._setup_mining_tab()
            self._setup_ai_tab()
            self._setup_settings_tab()
            self._setup_blockchain_tab()
            
            # Connect event handlers
            self._connect_event_handlers()
            
            # Start live data refresh
            self._start_live_data_refresh()
            
            self.logger.info("UI setup complete")
        except Exception as e:
            self.logger.error(f"Error setting up UI: {e}")
            self.logger.error(traceback.format_exc())
            
    def _create_styles(self) -> None:
        """Create custom styles for the UI."""
        try:
            # Create style object
            style = ttk.Style()
            
            # Configure existing styles
            style.configure("TFrame", background="#f0f0f0")
            style.configure("TLabel", background="#f0f0f0", font=("Helvetica", 10))
            style.configure("TButton", font=("Helvetica", 10))
            style.configure("TNotebook", background="#f0f0f0")
            style.configure("TNotebook.Tab", font=("Helvetica", 10, "bold"))
            
            # Custom styles
            style.configure("Header.TLabel", font=("Helvetica", 14, "bold"))
            style.configure("SubHeader.TLabel", font=("Helvetica", 12, "bold"))
            style.configure("Info.TLabel", foreground="#0066cc")
            style.configure("Success.TLabel", foreground="#009900")
            style.configure("Warning.TLabel", foreground="#cc6600")
            style.configure("Error.TLabel", foreground="#cc0000")
            
            # Frame styles
            style.configure("Card.TFrame", background="#ffffff", relief="raised")
            style.configure("QR.TFrame", background="#ffffff", relief="solid", borderwidth=1)
            
            self.logger.info("Custom styles created")
        except Exception as e:
            self.logger.error(f"Error creating styles: {e}")
            self.logger.error(traceback.format_exc())
    
    def _setup_settings_tab(self) -> None:
        """Set up the settings tab with configuration options."""
        try:
            # Create settings tab
            self.settings_tab = ttk.Frame(self.notebook)
            self.notebook.add(self.settings_tab, text="Settings")
            
            # Create notebook for settings categories
            settings_notebook = ttk.Notebook(self.settings_tab)
            settings_notebook.pack(fill=tk.BOTH, expand=True, padx=5, pady=5)
            
            # API Keys settings panel
            api_frame = ttk.Frame(settings_notebook)
            settings_notebook.add(api_frame, text="API Keys")
            
