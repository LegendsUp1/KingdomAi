            version_label.pack()
            
            about_text = scrolledtext.ScrolledText(about_frame, height=10, width=50, wrap=tk.WORD)
            about_text.pack(fill=tk.BOTH, expand=True, padx=10, pady=10)
            about_text.insert(tk.END, "Kingdom AI System is a comprehensive platform for cryptocurrency trading, ")
            about_text.insert(tk.END, "mining, and AI-assisted analysis. The system integrates with various ")
            about_text.insert(tk.END, "cryptocurrency exchanges, provides mining management, and offers ")
            about_text.insert(tk.END, "AI-driven insights for optimal trading strategies.\n\n")
            about_text.insert(tk.END, "Developed by: Kingdom AI Team\n")
            about_text.insert(tk.END, " 2023 Kingdom AI. All rights reserved.")
            about_text.configure(state=tk.DISABLED)  # Make read-only
            
            # Register widgets for updates
            self.widget_registry.register_widget("api_list", self.api_list)
            
            # Request current settings data
            self.event_bus.publish("settings.request_data", {})
            
            self.logger.info("Settings tab setup complete")
        except Exception as e:
            self.logger.error(f"Error setting up settings tab: {e}")
            self.logger.error(traceback.format_exc())
            
    def _add_update_api_key(self, service: str, key: str, secret: str) -> None:
        """Add or update an API key."""
        try:
            if not service:
                messagebox.showwarning("Missing Service", "Please select a service")
                return
                
            if not key:
                messagebox.showwarning("Missing Key", "Please enter an API key")
                return
                
            # Publish event to add/update API key
            self.event_bus.publish("api.key.update", {
                "service": service,
                "key": key,
                "secret": secret
            })
            
            messagebox.showinfo("API Key", f"API key for {service} has been updated")
            
        except Exception as e:
            self.logger.error(f"Error adding/updating API key: {e}")
            messagebox.showerror("API Key Error", f"Failed to update API key: {str(e)}")
            
    def _test_api_connection(self, service: str, key: str, secret: str) -> None:
        """Test API connection."""
        try:
            if not service:
                messagebox.showwarning("Missing Service", "Please select a service")
                return
                
            if not key:
                messagebox.showwarning("Missing Key", "Please enter an API key")
                return
                
            # Publish event to test API connection
            self.event_bus.publish("api.test.connection", {
                "service": service,
                "key": key,
                "secret": secret
            })
            
            messagebox.showinfo("API Connection", f"Testing connection to {service}...")
            
        except Exception as e:
            self.logger.error(f"Error testing API connection: {e}")
            messagebox.showerror("API Test Error", f"Failed to test API connection: {str(e)}")
            
    def _delete_api_key(self, service: str) -> None:
        """Delete an API key."""
        try:
            if not service:
                messagebox.showwarning("Missing Service", "Please select a service")
                return
                
            # Confirm deletion
            confirm = messagebox.askyesno("Confirm Deletion", 
                                        f"Are you sure you want to delete the API key for {service}?")
            if not confirm:
                return
                
            # Publish event to delete API key
            self.event_bus.publish("api.key.delete", {
                "service": service
            })
            
            messagebox.showinfo("API Key", f"API key for {service} has been deleted")
            
        except Exception as e:
            self.logger.error(f"Error deleting API key: {e}")
            messagebox.showerror("API Key Error", f"Failed to delete API key: {str(e)}")
            
    def _save_redis_settings(self, host: str, port: str, password: str) -> None:
        """Save Redis connection settings."""
        try:
            if not host:
                messagebox.showwarning("Missing Host", "Please enter a host")
                return
                
            try:
                port_int = int(port)
                if port_int <= 0 or port_int > 65535:
                    messagebox.showwarning("Invalid Port", "Port must be between 1 and 65535")
                    return
            except ValueError:
                messagebox.showwarning("Invalid Port", "Port must be a valid number")
                return
                
            # Publish event to save Redis settings
            self.event_bus.publish("redis.settings.update", {
                "host": host,
                "port": int(port),
                "password": password
            })
            
            messagebox.showinfo("Redis Settings", "Redis connection settings have been saved")
            
        except Exception as e:
            self.logger.error(f"Error saving Redis settings: {e}")
            messagebox.showerror("Redis Settings Error", f"Failed to save Redis settings: {str(e)}")
            
    def _test_redis_connection(self, host: str, port: str, password: str) -> None:
        """Test Redis connection."""
        try:
            if not host:
                messagebox.showwarning("Missing Host", "Please enter a host")
                return
                
            try:
                port_int = int(port)
                if port_int <= 0 or port_int > 65535:
                    messagebox.showwarning("Invalid Port", "Port must be between 1 and 65535")
                    return
            except ValueError:
                messagebox.showwarning("Invalid Port", "Port must be a valid number")
                return
                
            # Publish event to test Redis connection
            self.event_bus.publish("redis.test.connection", {
                "host": host,
                "port": int(port),
                "password": password
            })
            
            messagebox.showinfo("Redis Connection", "Testing Redis connection...")
            
        except Exception as e:
            self.logger.error(f"Error testing Redis connection: {e}")
            messagebox.showerror("Redis Connection Error", f"Failed to test Redis connection: {str(e)}")
            
    def _save_system_settings(self, theme: str, log_level: str, auto_connect: bool) -> None:
        """Save system settings."""
        try:
            # Publish event to save system settings
            self.event_bus.publish("system.settings.update", {
                "theme": theme,
                "log_level": log_level,
                "auto_connect": auto_connect
            })
            
            # Apply theme if changed
            self._apply_theme(theme)
            
            # Update log level if changed
            self._update_log_level(log_level)
            
            messagebox.showinfo("System Settings", "System settings have been saved")
            
        except Exception as e:
            self.logger.error(f"Error saving system settings: {e}")
            messagebox.showerror("System Settings Error", f"Failed to save system settings: {str(e)}")
            
    def _reset_system_settings(self) -> None:
        """Reset system settings to defaults."""
        try:
            # Confirm reset
            confirm = messagebox.askyesno("Confirm Reset", 
                                        "Are you sure you want to reset system settings to defaults?")
            if not confirm:
                return
                
            # Publish event to reset system settings
            self.event_bus.publish("system.settings.reset", {})
            
            messagebox.showinfo("System Settings", "System settings have been reset to defaults")
            
        except Exception as e:
            self.logger.error(f"Error resetting system settings: {e}")
            messagebox.showerror("System Settings Error", f"Failed to reset system settings: {str(e)}")
            
    def _apply_theme(self, theme: str) -> None:
        """Apply the selected theme."""
        try:
            style = ttk.Style()
            
            if theme == "Dark":
                # Dark theme settings
                style.configure("TFrame", background="#2e2e2e")
                style.configure("TLabel", background="#2e2e2e", foreground="#ffffff")
                style.configure("TButton", background="#3c3c3c")
                style.configure("TNotebook", background="#2e2e2e")
                style.configure("TNotebook.Tab", background="#3c3c3c", foreground="#ffffff")
                
                # Update text colors for custom styles
                style.configure("Header.TLabel", foreground="#ffffff")
                style.configure("SubHeader.TLabel", foreground="#ffffff")
                
                # Frame styles
                style.configure("Card.TFrame", background="#3c3c3c")
                
            elif theme == "Light" or theme == "System":  # Default is Light
                # Light theme settings (default)
                style.configure("TFrame", background="#f0f0f0")
                style.configure("TLabel", background="#f0f0f0", foreground="#000000")
                style.configure("TButton", background="#e0e0e0")
                style.configure("TNotebook", background="#f0f0f0")
                style.configure("TNotebook.Tab", background="#e0e0e0", foreground="#000000")
                
                # Update text colors for custom styles
                style.configure("Header.TLabel", foreground="#000000")
                style.configure("SubHeader.TLabel", foreground="#000000")
                
                # Frame styles
                style.configure("Card.TFrame", background="#ffffff")
                
            self.logger.info(f"Applied {theme} theme")
        except Exception as e:
            self.logger.error(f"Error applying theme: {e}")
            
    def _update_log_level(self, log_level: str) -> None:
        """Update the logging level."""
        try:
            # Map string level to logging constant
            level_map = {
                "DEBUG": logging.DEBUG,
                "INFO": logging.INFO,
                "WARNING": logging.WARNING,
                "ERROR": logging.ERROR,
                "CRITICAL": logging.CRITICAL
            }
            
            # Set root logger level
            level = level_map.get(log_level, logging.INFO)
            logging.getLogger().setLevel(level)
            
            # Update handler levels
            for handler in logging.getLogger().handlers:
                handler.setLevel(level)
                
            self.logger.info(f"Updated log level to {log_level}")
        except Exception as e:
            self.logger.error(f"Error updating log level: {e}")
    
    def _setup_blockchain_tab(self) -> None:
        """Set up the blockchain tab with wallet and transaction management."""
        try:
            # Create blockchain tab
            self.blockchain_tab = ttk.Frame(self.notebook)
            self.notebook.add(self.blockchain_tab, text="Blockchain")
            
            # Split into left and right panels
            left_panel = ttk.Frame(self.blockchain_tab)
            left_panel.pack(side=tk.LEFT, fill=tk.BOTH, expand=True, padx=5, pady=5)
            
            right_panel = ttk.Frame(self.blockchain_tab)
            right_panel.pack(side=tk.RIGHT, fill=tk.BOTH, expand=True, padx=5, pady=5)
            
            # Wallet section (left panel)
            wallet_frame = ttk.LabelFrame(left_panel, text="Wallet")
            wallet_frame.pack(fill=tk.BOTH, expand=False, padx=5, pady=5)
            
            # Wallet address
            address_frame = ttk.Frame(wallet_frame)
            address_frame.pack(fill=tk.X, padx=5, pady=5)
            
            ttk.Label(address_frame, text="Address:").pack(side=tk.LEFT, padx=5)
            address_var = tk.StringVar(value="Loading...")
            address_label = ttk.Label(address_frame, textvariable=address_var, font=("Consolas", 9))
            address_label.pack(side=tk.LEFT, fill=tk.X, expand=True, padx=5)
            
            # Copy address button
            copy_button = ttk.Button(address_frame, text="Copy", 
                                   command=lambda: self._copy_to_clipboard(address_var.get()))
            copy_button.pack(side=tk.RIGHT, padx=5)
            
            # Balance display
            balance_frame = ttk.Frame(wallet_frame)
            balance_frame.pack(fill=tk.X, padx=5, pady=5)
            
            ttk.Label(balance_frame, text="Balance:").pack(side=tk.LEFT, padx=5)
            balance_var = tk.StringVar(value="Loading...")
            balance_label = ttk.Label(balance_frame, textvariable=balance_var, font=("Helvetica", 12, "bold"))
            balance_label.pack(side=tk.LEFT, padx=5)
            
            # Refresh button
            refresh_button = ttk.Button(balance_frame, text="Refresh", 
                                      command=lambda: self.event_bus.publish("wallet.refresh", {}))
            refresh_button.pack(side=tk.RIGHT, padx=5)
            
            # Send/Receive buttons
            button_frame = ttk.Frame(wallet_frame)
            button_frame.pack(fill=tk.X, padx=5, pady=10)
            
            send_button = ttk.Button(button_frame, text="Send", 
                                    command=self._show_send_transaction_dialog)
            send_button.pack(side=tk.LEFT, padx=5, expand=True, fill=tk.X)
            
            receive_button = ttk.Button(button_frame, text="Receive", 
                                       command=self._show_receive_dialog)
            receive_button.pack(side=tk.RIGHT, padx=5, expand=True, fill=tk.X)
            
            # Transaction history section
            history_frame = ttk.LabelFrame(left_panel, text="Transaction History")
            history_frame.pack(fill=tk.BOTH, expand=True, padx=5, pady=5)
            
            # Transaction list
            self.tx_list = ttk.Treeview(history_frame, columns=("date", "type", "amount", "status"), show="headings")
            self.tx_list.heading("date", text="Date")
            self.tx_list.heading("type", text="Type")
            self.tx_list.heading("amount", text="Amount")
            self.tx_list.heading("status", text="Status")
            
            self.tx_list.column("date", width=100)
            self.tx_list.column("type", width=80)
            self.tx_list.column("amount", width=100)
            self.tx_list.column("status", width=80)
            
            self.tx_list.pack(fill=tk.BOTH, expand=True, padx=5, pady=5)
            
            # Add scrollbar
            scrollbar = ttk.Scrollbar(history_frame, orient=tk.VERTICAL, command=self.tx_list.yview)
            scrollbar.pack(side=tk.RIGHT, fill=tk.Y)
            self.tx_list.configure(yscrollcommand=scrollbar.set)
            
            # Blockchain explorer section (right panel)
            explorer_frame = ttk.LabelFrame(right_panel, text="Blockchain Explorer")
            explorer_frame.pack(fill=tk.BOTH, expand=True, padx=5, pady=5)
            
            # Network selection
            network_frame = ttk.Frame(explorer_frame)
            network_frame.pack(fill=tk.X, padx=5, pady=5)
            
            ttk.Label(network_frame, text="Network:").pack(side=tk.LEFT, padx=5)
            network_var = tk.StringVar(value="Ethereum")
            network_combo = ttk.Combobox(network_frame, textvariable=network_var, 
                                        values=["Ethereum", "Bitcoin", "Polygon", "Binance Smart Chain"])
            network_combo.pack(side=tk.LEFT, fill=tk.X, expand=True, padx=5)
            
            # Explorer search
            search_frame = ttk.Frame(explorer_frame)
            search_frame.pack(fill=tk.X, padx=5, pady=5)
            
            ttk.Label(search_frame, text="Search:").pack(side=tk.LEFT, padx=5)
            search_var = tk.StringVar()
            search_entry = ttk.Entry(search_frame, textvariable=search_var)
            search_entry.pack(side=tk.LEFT, fill=tk.X, expand=True, padx=5)
            
            search_button = ttk.Button(search_frame, text="Go", 
                                      command=lambda: self._search_blockchain(network_var.get(), search_var.get()))
            search_button.pack(side=tk.RIGHT, padx=5)
            
            # Explorer results
            results_frame = ttk.Frame(explorer_frame)
            results_frame.pack(fill=tk.BOTH, expand=True, padx=5, pady=5)
            
            explorer_text = scrolledtext.ScrolledText(results_frame, height=15, wrap=tk.WORD)
            explorer_text.pack(fill=tk.BOTH, expand=True, padx=5, pady=5)
            explorer_text.insert(tk.END, "Enter an address, transaction hash, or block number and click 'Go'")
            explorer_text.configure(state=tk.DISABLED)  # Make read-only
            
            # Network status
            status_frame = ttk.Frame(explorer_frame)
            status_frame.pack(fill=tk.X, padx=5, pady=5)
            
            ttk.Label(status_frame, text="Status:").pack(side=tk.LEFT, padx=5)
            status_var = tk.StringVar(value="Disconnected")
            status_label = ttk.Label(status_frame, textvariable=status_var)
            status_label.pack(side=tk.LEFT, padx=5)
            
            connect_button = ttk.Button(status_frame, text="Connect", 
                                       command=lambda: self.event_bus.publish("blockchain.connect", 
                                                                           {"network": network_var.get()}))
            connect_button.pack(side=tk.RIGHT, padx=5)
            
            # Registered widgets for updates
            self.widget_registry.register_widget("blockchain_address", address_var)
            self.widget_registry.register_widget("blockchain_balance", balance_var)
            self.widget_registry.register_widget("blockchain_tx_list", self.tx_list)
            self.widget_registry.register_widget("blockchain_explorer", explorer_text)
            self.widget_registry.register_widget("blockchain_status", status_var)
            
            # Request wallet data
            self.event_bus.publish("wallet.request_data", {})
            
            self.logger.info("Blockchain tab setup complete")
        except Exception as e:
            self.logger.error(f"Error setting up blockchain tab: {e}")
            self.logger.error(traceback.format_exc())
            
    def _copy_to_clipboard(self, text: str) -> None:
        """Copy text to clipboard."""
        try:
            self.root.clipboard_clear()
            self.root.clipboard_append(text)
            self.logger.info(f"Copied to clipboard: {text}")
        except Exception as e:
            self.logger.error(f"Error copying to clipboard: {e}")
            
    def _show_send_transaction_dialog(self) -> None:
        """Show dialog for sending a transaction."""
        try:
            send_window = tk.Toplevel(self.root)
            send_window.title("Send Transaction")
            send_window.geometry("400x300")
            send_window.grab_set()  # Make window modal
            
            # Create the content
            header_label = ttk.Label(send_window, text="Send Transaction", style="Header.TLabel")
            header_label.pack(padx=10, pady=10)
            
            # Recipient address
            address_frame = ttk.Frame(send_window)
            address_frame.pack(fill=tk.X, padx=10, pady=5)
            
            ttk.Label(address_frame, text="Recipient:").pack(side=tk.LEFT, padx=5)
            address_var = tk.StringVar()
            address_entry = ttk.Entry(address_frame, textvariable=address_var, width=40)
            address_entry.pack(side=tk.LEFT, fill=tk.X, expand=True, padx=5)
            
            # Amount
            amount_frame = ttk.Frame(send_window)
            amount_frame.pack(fill=tk.X, padx=10, pady=5)
            
            ttk.Label(amount_frame, text="Amount:").pack(side=tk.LEFT, padx=5)
            amount_var = tk.StringVar()
            amount_entry = ttk.Entry(amount_frame, textvariable=amount_var)
            amount_entry.pack(side=tk.LEFT, padx=5)
            
            # Currency
            currency_var = tk.StringVar(value="ETH")
            currency_combo = ttk.Combobox(amount_frame, textvariable=currency_var, 
                                         values=["ETH", "BTC", "MATIC", "BNB"], width=5)
            currency_combo.pack(side=tk.LEFT, padx=5)
            
            # Gas price (for Ethereum)
            gas_frame = ttk.Frame(send_window)
            gas_frame.pack(fill=tk.X, padx=10, pady=5)
            
            ttk.Label(gas_frame, text="Gas Price:").pack(side=tk.LEFT, padx=5)
            gas_var = tk.StringVar(value="Standard")
            gas_combo = ttk.Combobox(gas_frame, textvariable=gas_var, 
                                    values=["Low", "Standard", "Fast"], width=10)
            gas_combo.pack(side=tk.LEFT, padx=5)
            
            # Note/memo
            note_frame = ttk.Frame(send_window)
            note_frame.pack(fill=tk.X, padx=10, pady=5)
            
            ttk.Label(note_frame, text="Note:").pack(side=tk.LEFT, padx=5)
            note_var = tk.StringVar()
            note_entry = ttk.Entry(note_frame, textvariable=note_var)
            note_entry.pack(side=tk.LEFT, fill=tk.X, expand=True, padx=5)
            
            # Buttons at bottom
            button_frame = ttk.Frame(send_window)
            button_frame.pack(fill=tk.X, padx=10, pady=10)
            
            send_button = ttk.Button(button_frame, text="Send", 
                                    command=lambda: self._send_transaction(address_var.get(), 
                                                                         amount_var.get(), 
                                                                         currency_var.get(), 
                                                                         gas_var.get(), 
                                                                         note_var.get(), 
                                                                         send_window))
            send_button.pack(side=tk.RIGHT, padx=5)
            
            cancel_button = ttk.Button(button_frame, text="Cancel", 
                                      command=send_window.destroy)
            cancel_button.pack(side=tk.RIGHT, padx=5)
            
        except Exception as e:
            self.logger.error(f"Error showing send transaction dialog: {e}")
            self.logger.error(traceback.format_exc())
            
    def _send_transaction(self, recipient: str, amount: str, currency: str, 
                         gas_price: str, note: str, dialog: tk.Toplevel) -> None:
        """Send a blockchain transaction."""
        try:
            # Validate inputs
            if not recipient:
                messagebox.showerror("Invalid Transaction", "Recipient address cannot be empty")
                return
                
            try:
                amount_float = float(amount)
                if amount_float <= 0:
                    messagebox.showerror("Invalid Transaction", "Amount must be greater than zero")
                    return
            except ValueError:
                messagebox.showerror("Invalid Transaction", "Amount must be a valid number")
                return
                
            # Prepare transaction data
            tx_data = {
                "recipient": recipient,
                "amount": float(amount),
                "currency": currency,
                "gas_price": gas_price,
                "note": note,
                "timestamp": datetime.now().isoformat()
            }
            
            # Confirm transaction
            confirm = messagebox.askyesno("Confirm Transaction", 
                                        f"Send {amount} {currency} to {recipient}?")
            if not confirm:
                return
                
            # Close the dialog
            dialog.destroy()
            
            # Publish transaction event
            self.event_bus.publish("wallet.send_transaction", tx_data)
            
            # Show processing notification
            messagebox.showinfo("Transaction Sent", 
                              f"Transaction of {amount} {currency} has been submitted")
            
        except Exception as e:
            self.logger.error(f"Error sending transaction: {e}")
            messagebox.showerror("Transaction Error", f"Failed to send transaction: {str(e)}")
            
