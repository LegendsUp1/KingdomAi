    def _apply_mining_config(self, algorithm: str, pool_url: str, wallet: str, worker: str, threads: str) -> None:
        """Apply mining configuration through the event bus."""
        try:
            # Validate inputs
            if not pool_url:
                messagebox.showerror("Invalid Configuration", "Pool URL cannot be empty")
                return
                
            if not wallet:
                messagebox.showerror("Invalid Configuration", "Wallet address cannot be empty")
                return
                
            # Prepare configuration data
            config_data = {
                "algorithm": algorithm,
                "pool_url": pool_url,
                "wallet": wallet,
                "worker": worker,
                "threads": int(threads)
            }
            
            # Publish configuration event
            self.event_bus.publish("mining.update_config", config_data)
            
            # Show confirmation
            messagebox.showinfo("Configuration Updated", "Mining configuration has been updated")
            
        except ValueError as e:
            messagebox.showerror("Input Error", f"Invalid number format: {str(e)}")
        except Exception as e:
            self.logger.error(f"Error applying mining configuration: {e}")
            messagebox.showerror("Configuration Error", f"Failed to update configuration: {str(e)}")
            
    def _setup_ai_tab(self) -> None:
        """Set up the AI tab with Thoth chat interface and voice controls."""
        try:
            # Create AI tab
            self.ai_tab = ttk.Frame(self.notebook)
            self.notebook.add(self.ai_tab, text="ThothAI")
            
            # Split into top and bottom panels
            top_panel = ttk.Frame(self.ai_tab)
            top_panel.pack(fill=tk.BOTH, expand=True, padx=5, pady=5)
            
            bottom_panel = ttk.Frame(self.ai_tab)
            bottom_panel.pack(fill=tk.X, expand=False, padx=5, pady=5)
            
            # Left side: Chat interface
            chat_frame = ttk.LabelFrame(top_panel, text="ThothAI Assistant")
            chat_frame.pack(side=tk.LEFT, fill=tk.BOTH, expand=True, padx=5, pady=5)
            
            # Chat history
            self.chat_history = scrolledtext.ScrolledText(chat_frame, wrap=tk.WORD, height=20)
            self.chat_history.pack(fill=tk.BOTH, expand=True, padx=5, pady=5)
            self.chat_history.insert(tk.END, "ThothAI: Welcome to Kingdom AI. How can I assist you today?\n\n")
            self.chat_history.configure(state=tk.DISABLED)  # Make read-only
            
            # Right side: Controls and settings
            control_frame = ttk.LabelFrame(top_panel, text="AI Controls")
            control_frame.pack(side=tk.RIGHT, fill=tk.BOTH, expand=False, padx=5, pady=5, ipadx=5, ipady=5)
            
            # AI model selection
            model_frame = ttk.Frame(control_frame)
            model_frame.pack(fill=tk.X, padx=5, pady=5)
            
            ttk.Label(model_frame, text="AI Model:").pack(side=tk.LEFT, padx=5)
            model_var = tk.StringVar(value="Ollama (Llama2)")
            model_combo = ttk.Combobox(model_frame, textvariable=model_var, 
                                      values=["Ollama (Llama2)", "Ollama (Mistral)", "Ollama (Mixtral)", "Fallback Model"])
            model_combo.pack(side=tk.LEFT, fill=tk.X, expand=True, padx=5)
            
            # Connection status
            status_frame = ttk.Frame(control_frame)
            status_frame.pack(fill=tk.X, padx=5, pady=5)
            
            ttk.Label(status_frame, text="Status:").pack(side=tk.LEFT, padx=5)
            ai_status_var = tk.StringVar(value="Connecting...")
