    raise RuntimeError("Redis is required for Kingdom AI") from e

# PyQt6 imports - required for Kingdom AI
try:
    from PyQt6.QtWidgets import (
        QWidget, QVBoxLayout, QLabel, QTabWidget, QApplication, QSplitter,
        QComboBox, QPushButton, QLineEdit, QTextEdit, QToolBar, QMenu,
        QMainWindow, QMessageBox, QDialog, QScrollArea, QHBoxLayout, QFrame,
        QGridLayout, QSizePolicy
    )
    from PyQt6.QtCore import Qt, QSize, QTimer, pyqtSignal, QObject, QThread
    from PyQt6.QtGui import QFont, QIcon, QAction
    HAS_PYQT6 = True
except ImportError as e:
    logging.critical(f"PyQt6 import failed: {e} - Kingdom AI requires PyQt6")
    raise RuntimeError("PyQt6 is required for Kingdom AI GUI") from e

# Configure logging
logging.basicConfig(
    level=logging.DEBUG,
    format='%(asctime)s - %(name)s - %(levelname)s - %(message)s',
    handlers=[
        logging.StreamHandler(),
        logging.FileHandler('tab_manager.log')
    ]
)
logger = logging.getLogger(__name__)

# Core imports
from core.base_component import BaseComponent
from core.event_bus import EventBus
from core.redis_connector import RedisConnector as CoreRedisConnector

# First-party imports
from gui.kingdom_style import KingdomStyles

# Matplotlib imports - REQUIRED for Kingdom AI's charting functionality
try:
    import matplotlib
